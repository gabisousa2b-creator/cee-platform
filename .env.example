# ── Plateforme CEE — Configuration ──────────────────────────────────────────

# Mot de passe admin (défaut : Perruche2b)
ADMIN_PASSWORD=Perruche2b

# URL publique de la plateforme (pour les liens dans les emails)
PLATFORM_URL=http://localhost:3000

# ── Analyse IA des documents (Claude API) ────────────────────────────────────
# Obtenez votre clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Nodemailer) ────────────────────────────────────────────────────────
# Pour Gmail : activez "Mots de passe d'application" dans votre compte Google
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=Plateforme CEE
